generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Result {
  id              Int      @id @default(autoincrement())
  provider        String
  model           String
  alias           String?
  timestamp       DateTime @default(now())
  success         Boolean  @default(true)
  ttftMs          Int?
  tps             Float?
  totalTimeMs     Int?
  tokensGenerated Int?
  promptSent      String?
  errorMessage    String?

  @@index([provider, model, timestamp])
}

model CommunityResult {
  id          Int      @id @default(autoincrement())
  provider    String
  model       String
  alias       String?
  timestamp   DateTime @default(now())
  ttftMs      Int?
  tps         Float?

  @@index([provider, model, timestamp])
}

model User {
  id           Int      @id @default(autoincrement())
  username     String   @unique
  passwordHash String
  role         String   @default("user")
  createdAt    DateTime @default(now())
}
